{
  "name": "smart-autoscale-app",
  "version": "1.0.0",
  "description": "Smart Auto-Scaling Incident Response System - Node.js microservice",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "lint": "eslint src/ --ext .js"
  },
  "keywords": ["devops", "kubernetes", "autoscaling", "prometheus", "monitoring"],
  "author": "DevOps Engineer",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "testTimeout": 15000
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
